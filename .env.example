# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-5

# --- App ---
SKILL_CATALOG_PATH=data/skill_catalog.json
MAX_ZIP_SIZE_MB=25
MAX_FILES_READ=40
MAX_FILE_READ_BYTES=20000
DEFAULT_QUESTIONS_PER_SKILL=2

# --- Proctoring thresholds (seconds) ---
GAZE_OFF_LOW_S=3.0
GAZE_OFF_MEDIUM_S=8.0
FACE_NOT_DETECTED_LOW_S=3.0
FACE_NOT_DETECTED_MEDIUM_S=8.0

# --- Integrity score weights (deducted per flag, by severity) ---
SEVERITY_WEIGHT_LOW=0.02
SEVERITY_WEIGHT_MEDIUM=0.06
SEVERITY_WEIGHT_HIGH=0.15

# --- Risk level cut points (on final 0-1 integrity_score) ---
RISK_LOW_MIN_SCORE=0.75
RISK_MEDIUM_MIN_SCORE=0.5

# --- Watchdog: flags a session if no events arrive for this long ---
CONNECTION_TIMEOUT_S=12.0
WATCHDOG_POLL_INTERVAL_S=3.0
